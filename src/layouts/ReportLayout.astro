---
import BaseHead from "../components/BaseHead.astro";
import Mesh from "../components/Mesh.astro";
import Guides from "../components/Guides.astro";
import Masthead from "../components/Masthead.astro";
import Iris from "../components/Iris.astro";
import Footer from "../components/Footer.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import TableOfContents from "../components/TableOfContents.astro";
import AiMetaBadge from "../components/AiMetaBadge.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import CitationTooltip from "../components/CitationTooltip.astro";
import { formatDate } from "../utils/date";
import { readingTime } from "../utils/reading-time";
import { getPublishedReports } from "../utils/reports";
import { reportToPost } from "../lib/reports-to-posts";
import { hashSeed, mulberry, themeFor } from "../lib/theme-generator";
import { getCollection } from "astro:content";
import "../styles/global.css";

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  body: string;
  aiModel?: string;
  aiPrompt?: string;
  aiGeneratedDate?: Date;
  humanReviewed?: boolean;
  zhUrl?: string;
}

const {
  id,
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  headings,
  body,
  aiModel,
  aiPrompt,
  aiGeneratedDate,
  humanReviewed,
  zhUrl,
} = Astro.props;

const zhLink = zhUrl ?? `https://pro.mashbean.net/reports/${id}/`;

const kicker = tags[0] ?? "Essay";
const readTime = readingTime(body);
const ogImage = `og/${id}.png`;

// 此篇文章是否有對應的論證地圖（argmap）？
const argmaps = await getCollection("argmaps");
const matchedArgmap = argmaps.find((a) => a.data.slug === id);
const argmapHref = matchedArgmap ? `/argmaps/${matchedArgmap.id}/` : undefined;

// Related pool — everything except this report
const allReports = await getPublishedReports();
const otherPosts = allReports
  .filter((r) => r.id !== id)
  .map(reportToPost);
const relatedRandom = mulberry(hashSeed(`${id}:related`));
const relatedPosts = [...otherPosts]
  .sort(() => relatedRandom() - 0.5)
  .slice(0, 3)
  .map((post) => ({
    post,
    theme: themeFor(post.id),
  }));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body>
    <Mesh />
    <Guides />
    <ReadingProgress />
    <Masthead />

    <article class="article">
      <div class="article__topnav">
        <a href="/" class="article__back">← All essays</a>
        <a
          href={zhLink}
          class="article__lang"
          hreflang="zh-Hant"
          rel="alternate"
        >
          中文版 ↗
        </a>
      </div>

      <p class="article__kicker">{kicker}</p>
      <h1 class="article__title">{title}</h1>
      <p class="article__lede">“{description}”</p>

      <div class="article__meta">
        <span>
          <strong>{aiModel ?? "AI Research Pipeline"}</strong>
        </span>
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && <span>· Updated {formatDate(updatedDate)}</span>}
        <span>{readTime}</span>
        <span style="margin-left:auto">#{id.split("/").pop()}</span>
      </div>

      {tags.length > 0 && (
        <div class="article__tags">
          {tags.map((tag) => (
            <a class="article__tag" href={`/tags/${tag}/`}>#{tag}</a>
          ))}
        </div>
      )}

      <AiMetaBadge
        aiModel={aiModel}
        aiPrompt={aiPrompt}
        aiGeneratedDate={aiGeneratedDate}
        humanReviewed={humanReviewed}
      />

      {argmapHref && (
        <a class="article__argmap-link" href={argmapHref}>
          <span class="article__argmap-icon">◇</span>
          <span class="article__argmap-text">
            <strong>Argument Map</strong>
            <em>core thesis · supporting arguments · causal chain · border conditions</em>
          </span>
          <span class="article__argmap-arrow">→</span>
        </a>
      )}

      <div class="article__body report-prose">
        <slot />
      </div>

      <aside class="article__sidebar">
        <TableOfContents headings={headings} />
      </aside>
    </article>

    {relatedPosts.length > 0 && (
      <section class="related">
        <div class="related__head">
          <span class="related__label">Continue reading</span>
        </div>
        <div class="related__grid">
          {relatedPosts.map(({ post, theme }) => (
            <a
              href={post.href}
              class="related__item"
              style={`background: ${theme.bg}; color: ${theme.text};`}
            >
              <p class="related__author">{post.author}</p>
              <h3 class="related__title">{post.title}</h3>
            </a>
          ))}
        </div>
      </section>
    )}

    <Footer />
    <Iris />
    <ScrollReveal />
    <CitationTooltip />

    <style>
      .article__tags {
        display: flex;
        gap: var(--space-2);
        flex-wrap: wrap;
        margin: 0 0 var(--space-6);
      }
      .article__tag {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-ink-muted);
        text-decoration: none;
        padding: 2px 10px;
        border-radius: var(--radius-pill);
        border: 1px solid var(--color-rule);
        transition: all var(--dur-fast) var(--ease-standard);
      }
      .article__tag:hover {
        color: var(--color-ink);
        border-color: var(--color-ink);
      }
      .article__argmap-link {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        margin: var(--space-4) 0 var(--space-6);
        padding: var(--space-3) var(--space-4);
        background: var(--color-bg-muted);
        border: 1px solid var(--color-border);
        border-left: 3px solid var(--color-accent);
        border-radius: var(--radius-sm, 4px);
        text-decoration: none;
        color: var(--color-text);
        transition:
          border-color 0.2s ease,
          background 0.2s ease,
          transform 0.2s ease;
      }
      .article__argmap-link:hover {
        border-color: var(--color-accent);
        background: var(--color-accent-soft);
        transform: translateX(2px);
      }
      .article__argmap-icon {
        font-size: 1.4rem;
        color: var(--color-accent);
        line-height: 1;
      }
      .article__argmap-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }
      .article__argmap-text strong {
        font-family: var(--font-serif);
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.02em;
      }
      .article__argmap-text em {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-style: normal;
        color: var(--color-text-muted);
        letter-spacing: 0.04em;
      }
      .article__argmap-arrow {
        font-family: var(--font-mono);
        color: var(--color-text-muted);
        font-size: 1.1rem;
      }
      .article__argmap-link:hover .article__argmap-arrow {
        color: var(--color-accent);
      }
      .article__sidebar {
        display: none;
      }
      @media (min-width: 1100px) {
        .article {
          display: grid;
          grid-template-columns: minmax(0, 1fr) 220px;
          gap: var(--space-7);
          max-width: 960px;
          align-items: start;
        }
        .article > *:not(.article__sidebar) {
          grid-column: 1;
        }
        .article__sidebar {
          display: block;
          grid-column: 2;
          grid-row: 1 / span 8;
          position: sticky;
          top: var(--space-6);
        }
      }
    </style>
  </body>
</html>
