---
import BaseHead from "../components/BaseHead.astro";
import Mesh from "../components/Mesh.astro";
import Guides from "../components/Guides.astro";
import Masthead from "../components/Masthead.astro";
import Iris from "../components/Iris.astro";
import Footer from "../components/Footer.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import CitationTooltip from "../components/CitationTooltip.astro";
import { DEFAULT_AUTHOR } from "../site.config";
import { formatDate } from "../utils/date";
import { readingTime } from "../utils/reading-time";
import { getPublishedReports, getPublishedReportsZh } from "../utils/reports";
import { reportToPost } from "../lib/reports-to-posts";
import { hashSeed, mulberry, themeFor } from "../lib/theme-generator";
import { getCollection } from "astro:content";
import "../styles/global.css";

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  body: string;
  aiModel?: string;
  aiPrompt?: string;
  aiGeneratedDate?: Date;
  humanReviewed?: boolean;
  zhUrl?: string;
  locale?: "en" | "zh";
}

const {
  id,
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  headings,
  body,
  aiModel,
  aiPrompt,
  aiGeneratedDate,
  humanReviewed,
  zhUrl,
  locale = "en",
} = Astro.props;

// Determine the cross-language counterpart URL.
// Internal mirror by default (same slug in /zh/reports/ or /reports/);
// `zhUrl` frontmatter override is honoured for English pages whose Chinese
// counterpart lives outside this site (legacy).
const counterpartUrl = locale === "en"
  ? (zhUrl ?? `/zh/reports/${id}/`)
  : `/reports/${id}/`;

const counterpartLabel = locale === "en" ? "中文版" : "English";
const backLabel = locale === "en" ? "← All essays" : "← 所有文章";
const backHref = locale === "en" ? "/" : "/zh/";
const updatedLabel = locale === "en" ? "Updated" : "更新於";

const kicker = tags[0] ?? (locale === "en" ? "Essay" : "文章");
const readTime = readingTime(body);
const ogImage = `og/${id}.png`;

// 此篇文章是否有對應的論證地圖（argmap）？(English only for now)
const argmaps = await getCollection("argmaps");
const matchedArgmap = locale === "en" ? argmaps.find((a) => a.data.slug === id) : undefined;
const argmapHref = matchedArgmap ? `/argmaps/${matchedArgmap.id}/` : undefined;

// Related pool — everything except this report, drawn from the same locale.
const allReports = locale === "en"
  ? await getPublishedReports()
  : await getPublishedReportsZh();
const otherPosts = allReports
  .filter((r) => r.id !== id)
  .map(reportToPost);
const relatedRandom = mulberry(hashSeed(`${id}:related`));
const relatedPosts = [...otherPosts]
  .sort(() => relatedRandom() - 0.5)
  .slice(0, 3)
  .map((post) => ({
    post,
    theme: themeFor(post.id),
  }));
---

<!doctype html>
<html lang={locale === "zh" ? "zh-Hant" : "en"}>
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body>
    <Mesh />
    <Guides />
    <ReadingProgress />
    <Masthead locale={locale} />

    <article class="article">
      <div class="article__topnav">
        <a href={backHref} class="article__back">{backLabel}</a>
        <a
          href={counterpartUrl}
          class="article__lang"
          hreflang={locale === "en" ? "zh-Hant" : "en"}
          rel="alternate"
        >
          {counterpartLabel}
        </a>
      </div>

      <p class="article__kicker">{kicker}</p>
      <h1 class="article__title">{title}</h1>
      <p class="article__lede">“{description}”</p>

      <div class="article__meta">
        <span>
          <strong>{DEFAULT_AUTHOR}</strong>
        </span>
        <span class="article__wip" title="Work in progress — actively edited">WIP</span>
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate, locale)}</time>
        {updatedDate && <span>· {updatedLabel} {formatDate(updatedDate, locale)}</span>}
        <span>{readTime}</span>
        <span style="margin-left:auto">#{id.split("/").pop()}</span>
      </div>

      {argmapHref && (
        <a class="article__argmap-link" href={argmapHref}>
          <span class="article__argmap-icon">◇</span>
          <span class="article__argmap-text">
            <strong>{locale === "en" ? "Argument Map" : "論證地圖"}</strong>
            <em>{locale === "en"
              ? "core thesis · supporting arguments · causal chain · border conditions"
              : "核心論題 · 支持論點 · 因果鏈 · 邊界條件"}</em>
          </span>
          <span class="article__argmap-arrow">→</span>
        </a>
      )}

      <div class="article__body report-prose">
        <slot />
      </div>

      <aside class="article__sidebar">
        <TableOfContents headings={headings} />
      </aside>

      {/* ── Cite this working paper ───────────────────────────── */}
      <details class="article__cite">
        <summary>{locale === "en" ? "Cite this working paper" : "引用此工作論文"}</summary>
        <div class="article__cite-body">
          <p class="article__cite-note">
            {locale === "en"
              ? "Working paper; under active revision. Cite by canonical URL."
              : "工作論文，持續修訂中。請以標準網址引用。"}
          </p>
          <pre class="article__cite-block"><code>mashbean ({pubDate.getFullYear()}). {title}. civic-proof series, working paper. {Astro.site ?? "https://civic-proof.mashbean.net"}{locale === "en" ? `/reports/${id}/` : `/zh/reports/${id}/`}</code></pre>
          <pre class="article__cite-block"><code>@misc&#123;mashbean{pubDate.getFullYear()}-{id.replace(/-/g, "").slice(0, 12)},
  author = &#123;mashbean&#125;,
  title  = &#123;{title.replace(/&#123;|&#125;/g, "")}&#125;,
  year   = &#123;{pubDate.getFullYear()}&#125;,
  note   = &#123;civic-proof series, working paper&#125;,
  url    = &#123;{Astro.site ?? "https://civic-proof.mashbean.net"}{locale === "en" ? `/reports/${id}/` : `/zh/reports/${id}/`}&#125;
&#125;</code></pre>
        </div>
      </details>
    </article>

    {relatedPosts.length > 0 && (
      <section class="related">
        <div class="related__head">
          <span class="related__label">{locale === "en" ? "Continue reading" : "繼續閱讀"}</span>
        </div>
        <div class="related__grid">
          {relatedPosts.map(({ post, theme }) => (
            <a
              href={post.href}
              class="related__item"
              style={`background: ${theme.bg}; color: ${theme.text};`}
            >
              <p class="related__author">{post.author}</p>
              <h3 class="related__title">{post.title}</h3>
            </a>
          ))}
        </div>
      </section>
    )}

    <Footer locale={locale} />
    <Iris />
    <ScrollReveal />
    <CitationTooltip />

    <style>
      .article__cite {
        max-width: 760px;
        margin: var(--space-7) auto var(--space-6);
        padding: var(--space-3) var(--space-5);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        background: var(--color-bg-muted);
        font-family: var(--font-mono);
        font-size: 0.85rem;
      }
      .article__cite > summary {
        cursor: pointer;
        color: var(--color-ink-muted);
        text-transform: uppercase;
        letter-spacing: var(--tracking-wide);
        font-size: var(--text-xs);
        list-style: none;
        padding: var(--space-2) 0;
      }
      .article__cite > summary::before { content: "▸ "; }
      .article__cite[open] > summary::before { content: "▾ "; }
      .article__cite[open] > summary { color: var(--color-ink); margin-bottom: var(--space-3); }
      .article__cite-note {
        font-family: var(--font-body);
        font-size: 0.9rem;
        line-height: 1.5;
        color: var(--color-ink-muted);
        margin: 0 0 var(--space-3);
      }
      .article__cite-block {
        background: var(--color-canvas);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        padding: var(--space-3);
        margin: 0 0 var(--space-3);
        overflow-x: auto;
        font-size: 0.82rem;
        line-height: 1.55;
        white-space: pre-wrap;
        word-break: break-word;
      }
      .article__tags {
        display: flex;
        gap: var(--space-2);
        flex-wrap: wrap;
        margin: 0 0 var(--space-6);
      }
      .article__tag {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-ink-muted);
        text-decoration: none;
        padding: 2px 10px;
        border-radius: var(--radius-pill);
        border: 1px solid var(--color-rule);
        transition: all var(--dur-fast) var(--ease-standard);
      }
      .article__tag:hover {
        color: var(--color-ink);
        border-color: var(--color-ink);
      }
      .article__argmap-link {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        margin: var(--space-4) 0 var(--space-6);
        padding: var(--space-3) var(--space-4);
        background: var(--color-bg-muted);
        border: 1px solid var(--color-border);
        border-left: 3px solid var(--color-accent);
        border-radius: var(--radius-sm, 4px);
        text-decoration: none;
        color: var(--color-text);
        transition:
          border-color 0.2s ease,
          background 0.2s ease,
          transform 0.2s ease;
      }
      .article__argmap-link:hover {
        border-color: var(--color-accent);
        background: var(--color-accent-soft);
        transform: translateX(2px);
      }
      .article__argmap-icon {
        font-size: 1.4rem;
        color: var(--color-accent);
        line-height: 1;
      }
      .article__argmap-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }
      .article__argmap-text strong {
        font-family: var(--font-serif);
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.02em;
      }
      .article__argmap-text em {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-style: normal;
        color: var(--color-text-muted);
        letter-spacing: 0.04em;
      }
      .article__argmap-arrow {
        font-family: var(--font-mono);
        color: var(--color-text-muted);
        font-size: 1.1rem;
      }
      .article__argmap-link:hover .article__argmap-arrow {
        color: var(--color-accent);
      }
      .article__sidebar {
        display: none;
      }
      @media (min-width: 1100px) {
        .article {
          display: grid;
          grid-template-columns: minmax(0, 1fr) 220px;
          gap: var(--space-7);
          max-width: 960px;
          align-items: start;
        }
        .article > *:not(.article__sidebar) {
          grid-column: 1;
        }
        .article__sidebar {
          display: block;
          grid-column: 2;
          grid-row: 1 / span 8;
          position: sticky;
          top: var(--space-6);
        }
      }
    </style>
  </body>
</html>
