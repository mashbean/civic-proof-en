---
import BaseHead from "../components/BaseHead.astro";
import Mesh from "../components/Mesh.astro";
import Guides from "../components/Guides.astro";
import Masthead from "../components/Masthead.astro";
import Iris from "../components/Iris.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  fullTitle?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  /** Hide the default masthead when the page renders its own chrome. */
  bareChrome?: boolean;
  /** Hide the global mesh background on pages that want a clean canvas. */
  noMesh?: boolean;
  /** Locale for this page; controls Masthead labels and <html lang>. */
  locale?: "en" | "zh";
}

const {
  title,
  fullTitle,
  description,
  ogImage,
  noindex,
  bareChrome = false,
  noMesh = false,
  locale = "en",
} = Astro.props;
---

<!doctype html>
<html lang={locale === "zh" ? "zh-Hant" : "en"}>
  <head>
    <BaseHead title={title} fullTitle={fullTitle} description={description} ogImage={ogImage} noindex={noindex} />
  </head>
  <body>
    {!noMesh && <Mesh />}
    <Guides />
    {!bareChrome && <Masthead locale={locale} />}
    <slot />
    <Footer locale={locale} />
    <Iris />
    <ScrollReveal />
  </body>
</html>
