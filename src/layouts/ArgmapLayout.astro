---
import BaseHead from "../components/BaseHead.astro";
import Mesh from "../components/Mesh.astro";
import Guides from "../components/Guides.astro";
import Masthead from "../components/Masthead.astro";
import Footer from "../components/Footer.astro";
import Iris from "../components/Iris.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Argument Map — ${title}`} description={description} />
  </head>
  <body>
    <Mesh />
    <Guides />
    <Masthead />
    <main class="argmap-page">
      <slot />
    </main>
    <Footer />
    <Iris />
  </body>
</html>

<style>
  .argmap-page {
    padding-top: var(--space-6, 2rem);
    padding-bottom: var(--space-9, 6rem);
    padding-inline: var(--space-4, 1rem);
  }
</style>
