---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedReportsZh } from "../../utils/reports";

const reports = await getPublishedReportsZh();
const byId = new Map(reports.map((r) => [r.id, r]));

function pick(id: string) {
  const r = byId.get(id);
  if (!r) return null;
  return {
    id,
    href: `/zh/reports/${id}/`,
    title: r.data.title,
    description: r.data.description,
  };
}

const startHere = [
  {
    pick: pick("2026-05-17-civic-proof-foundations"),
    why: "整合整個系列的學術重述。要把框架一次看完就讀這篇。",
  },
  {
    pick: pick("2026-05-19-danielle-allen-power-sharing-civic-proof-bridge"),
    why: "AllenBridge：為什麼 Danielle Allen 的權力分享自由主義是 Public Realm Floor 通往數位公民建設的制度轉譯層，而不是第五軸。",
  },
  {
    pick: pick("2026-05-16-taiwan-civic-proof-deep-dive"),
    why: "把框架套到一個民主前線案例上。最具體的入口。",
  },
].filter((x) => x.pick);

const origin = pick("2026-04-17-from-state-credentials-to-civic-proof");

const normative = [
  "2026-05-12-public-realm-political-philosophy",
  "2026-05-02-accountability-without-identification",
  "2026-05-03-civic-proof-concept-positioning",
].map(pick).filter(Boolean);

const engineering = [
  "2026-05-10-civic-ai-agent-delegation-limits",
  "2026-05-11-civic-receipts-provenance",
  "2026-05-11-selective-disclosure-ux-failure",
  "2026-05-08-wallet-as-essential-facility",
  "2026-05-09-no-phone-home-engineering-economics",
].map(pick).filter(Boolean);

const cases = [
  "2026-05-16-taiwan-civic-proof-deep-dive",
  "2026-05-07-bankid-nordic-monopoly-democracy",
  "2026-05-08-digital-identity-civic-action-quant",
  "2026-05-09-cross-jurisdictional-redress-gap",
  "2026-05-06-dns-vs-identity-trust-roots",
].map(pick).filter(Boolean);

const stress = [
  "2026-05-09-structural-slippage-prevention",
  "2026-04-16-age-verification-digital-rights",
  "2026-05-05-passport-rooted-paradox",
  "2026-05-05-sybil-resistance-cost-benefit",
  "2026-05-04-pseudonymous-participation-legal",
  "2026-05-05-civic-burden-redistribution",
  "2026-05-10-civic-proof-inclusion-rights",
  "2026-05-03-digital-association-empirical-test",
].map(pick).filter(Boolean);

const retrofit = [
  "2026-04-01-agentic-id-governance",
  "2026-04-16-age-verification-digital-rights",
  "2026-03-28-gov-it-procurement-monopoly-or-innovation",
  "2026-05-01-did-vc-public-blockchain",
].map(pick).filter(Boolean);

const capstone = [
  "2026-05-16-civic-proof-series-capstone",
  "2026-05-17-civic-proof-foundations",
  "2026-05-19-danielle-allen-power-sharing-civic-proof-bridge",
].map(pick).filter(Boolean);
---

<BaseLayout locale="zh">
  <section class="series">
    <header class="series__head">
      <p class="series__kicker">civic-proof · 撰寫中</p>
      <h1 class="series__title">從國家發行憑證到公民證明自己。</h1>
      <p class="series__lede">
        公民證明（civic-proof）系列的閱讀順序。豆泥（mashbean）於哈佛甘迺迪政府學院
        Ash Center Allen Lab Fellowship 期間撰寫。
      </p>
    </header>

    <section class="series__section">
      <h2 class="series__h2">▸ 從這裡開始</h2>
      <p class="series__note">
        如果你只有一小時，讀這三篇。其餘的等你想深入時再翻。
      </p>
      <ol class="series__cards">
        {startHere.map((s) => (
          <li class="series__card series__card--featured">
            <a href={s.pick!.href}>
              <h3 class="series__card-title">{s.pick!.title}</h3>
              <p class="series__card-why">{s.why}</p>
            </a>
          </li>
        ))}
      </ol>
    </section>

    {origin && (
      <section class="series__section">
        <h2 class="series__h2">▸ 起點</h2>
        <p class="series__note">
          2026 年 4 月 17 日 Allen Lab Fellow Meeting 的簡報，整個系列的起點。
          豆泥本人的語氣，比較鬆。後面的學術版都是從這裡長出來的。
        </p>
        <ul class="series__list">
          <li>
            <a href={origin.href}>
              <span class="series__name">{origin.title}</span>
            </a>
          </li>
        </ul>
      </section>
    )}

    <section class="series__section">
      <h2 class="series__h2">▸ 規範錨點</h2>
      <p class="series__note">
        政治哲學下界。Arendt 的多元、Habermas 的有效性、Pettit 的異議可能性、
        Mouffe 的對抗政治——Public Realm Floor 由這四家合取構成。
      </p>
      <ul class="series__list">
        {normative.map((p) => (
          <li>
            <a href={p!.href}>
              <span class="series__name">{p!.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="series__section">
      <h2 class="series__h2">▸ 工程承擔</h2>
      <p class="series__note">
        規範下界遇上具體工程設計。皮夾、AI 代理委任、公民行動收據、
        選擇性揭露 UX、wallet-as-essential-facility 論證、不回撥。
      </p>
      <ul class="series__list">
        {engineering.map((p) => (
          <li>
            <a href={p!.href}>
              <span class="series__name">{p!.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="series__section">
      <h2 class="series__h2">▸ 案例與比較</h2>
      <p class="series__note">
        台灣作為民主前線深度案例、北歐 BankID、跨法域救濟、DNS 與身分信任根、
        以及一個跨國量化研究。
      </p>
      <ul class="series__list">
        {cases.map((p) => (
          <li>
            <a href={p!.href}>
              <span class="series__name">{p!.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="series__section">
      <h2 class="series__h2">▸ 壓力測試與邊界條件</h2>
      <p class="series__note">
        框架被加壓的地方：年齡驗證的結構性滑坡、護照根基悖論、假名式參與、
        抗 Sybil 攻擊的取捨、公民負擔重分配、納入性權利。
      </p>
      <ul class="series__list">
        {stress.map((p) => (
          <li>
            <a href={p!.href}>
              <span class="series__name">{p!.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="series__section">
      <h2 class="series__h2">▸ 回溯錨點</h2>
      <p class="series__note">
        早於系列的實證文章，事後被收編為錨點。
      </p>
      <ul class="series__list">
        {retrofit.map((p) => (
          <li>
            <a href={p!.href}>
              <span class="series__name">{p!.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="series__section">
      <h2 class="series__h2">▸ 收束、0' 重述、AllenBridge</h2>
      <p class="series__note">
        系列嘗試自我收束三次：原本的 capstone、學術版 0' 重述、Danielle Allen 橋接文。
      </p>
      <ul class="series__list">
        {capstone.map((p) => (
          <li>
            <a href={p!.href}>
              <span class="series__name">{p!.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="series__section">
      <h2 class="series__h2">▸ 延伸</h2>
      <ul class="series__list">
        <li>
          <a href="/zh/civic-proof-map/">
            <span class="series__name">整個系列的論證地圖</span>
          </a>
        </li>
        <li>
          <a href="/zh/about/">
            <span class="series__name">關於這個網站</span>
          </a>
        </li>
      </ul>
    </section>
  </section>
</BaseLayout>

<style>
  .series {
    max-width: 760px;
    margin: 0 auto;
    padding: var(--space-9) var(--space-5) var(--space-10);
  }
  .series__head { margin-bottom: var(--space-9); }
  .series__kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-3) 0;
  }
  .series__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-5) 0;
    color: var(--color-ink);
    text-wrap: balance;
  }
  .series__lede {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.7;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 60ch;
  }
  .series__section { margin-bottom: var(--space-9); }
  .series__h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    margin: 0 0 var(--space-3) 0;
    color: var(--color-ink);
  }
  .series__note {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-5) 0;
    max-width: 58ch;
  }
  .series__cards {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    gap: var(--space-4);
    counter-reset: cards;
  }
  .series__card {
    counter-increment: cards;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-canvas);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .series__card:hover {
    border-color: var(--color-ink);
    transform: translateY(-2px);
  }
  .series__card a {
    display: block;
    padding: var(--space-5) var(--space-5);
    color: inherit;
    text-decoration: none;
  }
  .series__card--featured::before {
    content: counter(cards);
    float: right;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    padding: 6px 10px;
    margin: 0 0 var(--space-3) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }
  .series__card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    line-height: 1.4;
    margin: 0 0 var(--space-3) 0;
    color: var(--color-ink);
  }
  .series__card-why {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .series__list {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    gap: 0;
  }
  .series__list li a {
    display: block;
    padding: var(--space-3) 0;
    border-top: 1px solid var(--color-border);
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .series__list li:last-child a {
    border-bottom: 1px solid var(--color-border);
  }
  .series__list li a:hover .series__name {
    color: var(--color-accent, var(--color-ink));
  }
  .series__name {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink);
  }
</style>
