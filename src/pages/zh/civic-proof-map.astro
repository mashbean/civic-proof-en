---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

// ── 19 篇文章規格 ───────────────────────────────────────────────
// 對應 dissertation-outline.md 的五部結構 + prompt 對映
type ArticleSpec = {
  no: string;          // 01..19
  prompt: string;      // A1..F3
  slug: string;        // matches reports/argmaps id (or stub for unpublished)
  title: string;       // 中文標題
  part: 1 | 2 | 3 | 4 | 5;
  chapter: string;     // 對應章節編號
};

const articles: ArticleSpec[] = [
  { no: "01", prompt: "A1", slug: "2026-05-02-accountability-without-identification", title: "Accountability without Real-Name Identification", part: 1, chapter: "Ch 3.4" },
  { no: "02", prompt: "A3", slug: "2026-05-03-civic-proof-concept-positioning", title: "Civic Proof: Concept and Conceptual Positioning", part: 1, chapter: "Ch 2.2" },
  { no: "03", prompt: "B1", slug: "2026-05-03-digital-association-empirical-test", title: "Freedom of Association × Digital Identity: An Empirical Test of the Three-Wall Hypothesis", part: 3, chapter: "Ch 8.3" },
  { no: "04", prompt: "C1", slug: "2026-05-04-pseudonymous-participation-legal", title: "The Legal Foundations of Pseudonymous Public Participation", part: 3, chapter: "Ch 8.2" },
  { no: "05", prompt: "C2", slug: "2026-05-05-sybil-resistance-cost-benefit", title: "The Cost-Benefit Matrix of Uniqueness Proof", part: 3, chapter: "Ch 8.1" },
  { no: "06", prompt: "C3", slug: "2026-05-05-civic-burden-redistribution", title: "Redistributing the Civic Burden", part: 2, chapter: "Ch 6.6" },
  { no: "07", prompt: "D2", slug: "2026-05-05-passport-rooted-paradox", title: "The Passport-Rooted Paradox", part: 2, chapter: "Ch 5.4" },
  { no: "08", prompt: "D3", slug: "2026-05-06-dns-vs-identity-trust-roots", title: "DNS Trust Roots vs Identity Trust Roots", part: 4, chapter: "Ch 11.4" },
  { no: "09", prompt: "D1", slug: "2026-05-07-bankid-nordic-monopoly-democracy", title: "The Nordic BankID Model: Commercial Monopoly and Democratic Resilience", part: 2, chapter: "Ch 4.4" },
  { no: "10", prompt: "B2", slug: "2026-05-08-digital-identity-civic-action-quant", title: "Cross-National Quantitative Study: Identity Systems × Freedom of Association", part: 2, chapter: "Ch 4.6" },
  { no: "11", prompt: "E1", slug: "2026-05-08-wallet-as-essential-facility", title: "Wallet as Essential Facility: Applying Antitrust Doctrine", part: 4, chapter: "Ch 10" },
  { no: "12", prompt: "E2", slug: "2026-05-09-no-phone-home-engineering-economics", title: "The Engineering Economics of No-Phone-Home", part: 4, chapter: "Ch 11.3" },
  { no: "13", prompt: "E3", slug: "2026-05-09-structural-slippage-prevention", title: "Age Verification and the Prevention of Structural Slippage", part: 3, chapter: "Ch 7" },
  { no: "14", prompt: "E4", slug: "2026-05-09-cross-jurisdictional-redress-gap", title: "The Cross-Jurisdictional Redress Gap", part: 4, chapter: "Ch 12.3" },
  { no: "15", prompt: "E5", slug: "2026-05-10-civic-proof-inclusion-rights", title: "Civic Proof Inclusion Rights: Alternative Pathways without a Wallet", part: 5, chapter: "Ch 14.4" },
  { no: "16", prompt: "F1", slug: "2026-05-10-civic-ai-agent-delegation-limits", title: "The Institutional Limits of AI Agents in Civic Action", part: 3, chapter: "Ch 9" },
  { no: "17", prompt: "F2", slug: "2026-05-11-civic-receipts-provenance", title: "Civic Receipts and the Chain of Provenance", part: 3, chapter: "Ch 9.3" },
  { no: "18", prompt: "F3", slug: "2026-05-11-selective-disclosure-ux-failure", title: "The Cognitive Limits of Selective Disclosure UX", part: 4, chapter: "Ch 10.3" },
  { no: "19", prompt: "A2", slug: "2026-05-12-public-realm-political-philosophy", title: "The Political-Philosophical Foundations of the Public Realm", part: 1, chapter: "Ch 2.5" },
  // ── Retrofit articles (R1–R4, earlier empirical anchors incorporated into the series) ───
  { no: "R1", prompt: "—", slug: "2026-04-01-agentic-id-governance", title: "Who Governs the Identity of AI Agents? (Agentic ID Governance)", part: 3, chapter: "Ch 9.1" },
  { no: "R2", prompt: "—", slug: "2026-04-16-age-verification-digital-rights", title: "Age Verification Regulation and the Digital Rights Landscape", part: 3, chapter: "Ch 7.1–7.2" },
  { no: "R3", prompt: "—", slug: "2026-03-28-gov-it-procurement-monopoly-or-innovation", title: "Public IT Procurement: Monopoly or Innovation?", part: 4, chapter: "Ch 12.1" },
  { no: "R4", prompt: "—", slug: "2026-05-01-did-vc-public-blockchain", title: "DID/VC on Public Blockchain: Decentralisation Pathways for Self-Sovereign Identity", part: 4, chapter: "Ch 11.2" },
];

// ── Meta articles (origin, capstones, deep-dive, bridge) ─────────────
// Not part of the 19-article main scaffolding; serve as framing pieces.
type MetaSpec = {
  no: string;
  slug: string;
  title: string;
  role: string;            // one-line description of structural role
};
const metaArticles: MetaSpec[] = [
  { no: "M0", slug: "2026-04-17-from-state-credentials-to-civic-proof",      title: "From State-Issued Credentials to Citizens Proving Themselves",                 role: "Origin · Allen Lab Fellow Meeting presentation (17 Apr 2026)" },
  { no: "M1", slug: "2026-05-16-taiwan-civic-proof-deep-dive",              title: "Taiwan as a Democratic-Frontline Stress Test",                                role: "Single-case deep-dive applying the framework end-to-end" },
  { no: "M2", slug: "2026-05-16-civic-proof-series-capstone",               title: "civic-proof Series — Capstone",                                               role: "Series closure: 19-article integration" },
  { no: "M3", slug: "2026-05-17-civic-proof-foundations",                   title: "civic-proof Foundations (0' Academic Restatement)",                            role: "Academic-register restatement of the 0417 origin, with PRF formal skeleton" },
  { no: "M4", slug: "2026-05-19-danielle-allen-power-sharing-civic-proof-bridge", title: "How Danielle Allen's Power-Sharing Liberalism Rewrites DCI",            role: "AllenBridge: translation layer between PRF and Digital Civic Infrastructure" },
];

// ── 五部 = 五母命題 ─────────────────────────────────────────────
type PartSpec = { id: 1 | 2 | 3 | 4 | 5; label: string; title: string; thesis: string };
const parts: PartSpec[] = [
  {
    id: 1,
    label: "P₁ 概念基礎",
    title: "基礎篇——公民證明作為概念工程",
    thesis: "公民證明 ≜ ⟨𝒩, ℱ, ℬ⟩。介於存在式身分與憑證式身分之間的第三類，由規範差異矩陣 𝒩、形式範圍 ℱ、哲學基礎 ℬ 三者合取定義。既有系統（如 KYC、SBT）無法同時滿足三項分量；以既有類別重新分類在事實上不成立。",
  },
  {
    id: 2,
    label: "P₂ 比較實證",
    title: "比較實證——五國叢集的覆蓋缺口",
    thesis: "在五個國家叢集（英澳／歐盟-瑞士／美國州級／北歐 BankID／全球南方）與護照根基領域中，既有系統在規範矩陣 𝒩 的至少一個維度上失效。實證紀錄不支持重新分類。",
  },
  {
    id: 3,
    label: "P₃ 規範壓力測試",
    title: "規範壓力測試——三條測試線",
    thesis: "面對三條規範測試線——年齡驗證（結構性滑坡）、假名與唯一性（結社自由與抗 Sybil）、AI 委任（公民行動的制度極限）——三分量形式 ⟨𝒩, ℱ, ℬ⟩ 必須滿足合取必要條件，並保持在機率降階邊界之內。",
  },
  {
    id: 4,
    label: "P₄ 制度與基礎設施設計",
    title: "制度與基礎設施設計——三層基礎設施",
    thesis: "從發證壟斷到呈現壟斷（皮夾／作業系統／瀏覽器作為守門者）→ 信任根與公共區塊鏈（DNS 與身分根的對偶 + 不回撥的工程經濟學）→ 採購政治經濟學（跨法域救濟缺口）。基礎設施層的設計決定形式範圍 ℱ 是否可被操作化。",
  },
  {
    id: 5,
    label: "P₅ 結論與政策議程",
    title: "結論與政策——聯邦式信任清單聯盟",
    thesis: "結論：可問責性不需要以實名為前提（A ⇐ P[U]）。政策議程：隱私優先底線＋聯邦式信任清單聯盟＋採購沙盒＋供應商多元化＋公民證明納入性權利（無皮夾的替代路徑）＋印太示範計畫。",
  },
];

// ── 從中文 collection 中查找實際發佈狀態與標題 ─────────────────
const argmaps = await getCollection("argmaps");
const reports = await getCollection("reportsZh");

const argmapBySlug = new Map(argmaps.map((a) => [a.id, a]));
const reportBySlug = new Map(reports.map((r) => [r.id, r]));

type EnrichedArticle = ArticleSpec & {
  hasReport: boolean;
  hasArgmap: boolean;
  reportHref?: string;
  argmapHref?: string;
  formalExpression?: string;
};

const enriched: EnrichedArticle[] = articles.map((a) => {
  const report = reportBySlug.get(a.slug);
  const argmap = argmapBySlug.get(a.slug);
  return {
    ...a,
    title: report?.data.title ?? a.title,
    hasReport: !!report,
    hasArgmap: !!argmap,
    reportHref: report ? `/zh/reports/${report.id}/` : undefined,
    argmapHref: argmap ? `/argmaps/${argmap.id}/` : undefined,
    formalExpression: argmap?.data.coreThesis.formal?.expression?.trim().split("\n")[0],
  };
});

const byPart = (id: 1 | 2 | 3 | 4 | 5) => enriched.filter((a) => a.part === id);

// ── 跨文章概念連結（formal logic 同構與遞迴） ──────────────────
type CrossLink = { from: string; to: string[]; label: string; formal: string };
const crossLinks: CrossLink[] = [
  {
    from: "01",
    to: ["02"],
    label: "V₁..V₆ procedural firewall ⊑ M₄ privacy measurement",
    formal: "article_01.{V₁..V₆}  ⊨  article_02.M₄.subspec",
  },
  {
    from: "02",
    to: ["01", "03", "04", "05", "06", "07", "08", "13", "15", "16", "17"],
    label: "𝒩(M₁..M₄) normative matrix is the backbone common to the entire series",
    formal: "∀ article_i ∈ {01..19} : ∃ Mⱼ : refines(article_i, Mⱼ)",
  },
  {
    from: "03",
    to: ["04", "05"],
    label: "Conjunctive necessary conditions W₁∧W₂∧W₃ ≅ T₁∧T₂∧T₃ ≅ ¬∃IT' — three-dimensional tension",
    formal: "isomorphic(article_03.H1', article_04.T, article_05.IT')",
  },
  {
    from: "04",
    to: ["06", "07", "14"],
    label: "T_Remedy remedy clause → CB-Justice D₂* + MR-CivicProof R₃R₄ + cross-jurisdictional redress gap",
    formal: "T_Remedy ⊨ {D₂*, R₃, R₄, redress_gap}",
  },
  {
    from: "07",
    to: ["08"],
    label: "Sovereignty premise SRP ↔ historical premise HM as dual (both are category-failure arguments)",
    formal: "dual(SRP : sovereignty_container, HM : historical_precondition)",
  },
  {
    from: "06",
    to: ["11", "15"],
    label: "Rawls lexical priority D₁* + Anderson democratic citizenship D₂* → essential facility + inclusion rights",
    formal: "{D₁*, D₂*} ⊨ {essential_facility, inclusion_rights}",
  },
  {
    from: "05",
    to: ["12", "13"],
    label: "IT' impossibility trilemma → no-phone-home engineering economics + structural slippage prevention",
    formal: "IT'(U, D, I)  ⇒  {no_phone_home, slippage_prevention}.constraints",
  },
  {
    from: "11",
    to: ["18"],
    label: "Essential facility doctrine ↔ cognitive limits of selective disclosure UX",
    formal: "essential_facility ∧ ¬cognitive_load_ok  ⇒  ¬accessible(UX)",
  },
  // ── Retrofit cross-links (R1–R4) ─────────────────────────────────
  {
    from: "R1",
    to: ["16", "17"],
    label: "Enterprise/institutional AI agent governance ⇒ civic complement + receipts provenance",
    formal: "agentic_id.{P_acc, P_legit, P_dist}  ⊨  civic_delegation.{micro-authenticity, 4-piece, liability_3tier}",
  },
  {
    from: "R2",
    to: ["13", "15"],
    label: "Age-verification experience across 25 jurisdictions ⇒ structural slippage prevention + civic proof inclusion for persons with disabilities",
    formal: "AV_regime.{tech × gov}  ⊨  slippage_prevention.{sunset, scope, selective}  ∧  CRPD_Art_29_aligned(disability)",
  },
  {
    from: "R3",
    to: ["14", "11"],
    label: "Procurement political economy (lock-in mechanisms × openness tools) ⇒ cross-jurisdictional redress + essential facility",
    formal: "Concentration_drivers ∪ Openness_tools  ⊨  ⟨redress_gap, essential_facility⟩",
  },
  {
    from: "R4",
    to: ["08", "12", "07"],
    label: "Public chain vs permissioned chain/PKI ⇒ DNS dual + no-phone-home engineering economics + passport-rooted paradox",
    formal: "Trust_root_choice = f(governance, regulatory, tech_readiness)  ;  isomorphic(R4, ⟨08, 12, 07⟩)",
  },
];

const partColors: Record<1 | 2 | 3 | 4 | 5, string> = {
  1: "color-mix(in oklab, var(--color-accent) 18%, var(--color-bg))",
  2: "color-mix(in oklab, #d4a373 22%, var(--color-bg))",
  3: "color-mix(in oklab, #8a7090 22%, var(--color-bg))",
  4: "color-mix(in oklab, #5b8a72 22%, var(--color-bg))",
  5: "color-mix(in oklab, #c97f5a 22%, var(--color-bg))",
};

// Enrich meta articles in the same shape (without prompt/part/chapter)
type EnrichedMeta = MetaSpec & {
  hasReport: boolean;
  hasArgmap: boolean;
  reportHref?: string;
  argmapHref?: string;
};
const enrichedMeta: EnrichedMeta[] = metaArticles.map((m) => {
  const report = reportBySlug.get(m.slug);
  const argmap = argmapBySlug.get(m.slug);
  return {
    ...m,
    title: report?.data.title ?? m.title,
    hasReport: !!report,
    hasArgmap: !!argmap,
    reportHref: report ? `/zh/reports/${report.id}/` : undefined,
    argmapHref: argmap ? `/argmaps/${argmap.id}/` : undefined,
  };
});

const stats = {
  total: articles.length + metaArticles.length,
  reports:
    enriched.filter((a) => a.hasReport).length +
    enrichedMeta.filter((a) => a.hasReport).length,
  argmaps:
    enriched.filter((a) => a.hasArgmap).length +
    enrichedMeta.filter((a) => a.hasArgmap).length,
};
---

<BaseLayout title="civic-proof：論證地圖" description="從國家發行憑證到公民證明自己——civic-proof 系列所有文章的母命題、子論證、跨文章概念連結。" locale="zh">
  <article class="map-page">
    <header class="map-page__header">
      <p class="map-page__kicker">主論證地圖</p>
      <h1 class="map-page__title">civic-proof：論證地圖</h1>
      <p class="map-page__subtitle">
        從國家發行憑證到公民證明自己——以數位身分重建民主信任
      </p>

      <div class="map-page__thesis">
        <p class="map-page__thesis-label">中心論題</p>
        <p class="map-page__thesis-body">
          民主社會所需要的「公民證明」不預設事前的完整身分識別；
          可問責性是<em>結果性條件</em>，不是<em>前提性條件</em>。
          將身分系統從「發證者中心」轉向「持有者中心＋多層信任」是必要的——
          但若缺乏對應的規範下界、平台層反壟斷限制、以及救濟機制，
          這個轉換會把民主成本轉嫁到最脆弱的使用者身上。
        </p>
        <pre class="map-page__formal"><code>CivicProof ≜ ⟨ 𝒩, ℱ, ℬ ⟩
A ⇐ P[U]   where   U valid ⇔ V₁ ∧ V₂ ∧ V₃ ∧ V₄ ∧ V₅ ∧ V₆
∀ article_i ∈ &#123;01..19&#125; : ∃ component ∈ &#123;𝒩, ℱ, ℬ&#125; : refines(article_i, component)</code></pre>
      </div>

      <div class="map-page__stats">
        <span><strong>{stats.total}</strong> 篇文章</span>
        <span><strong>{stats.reports}</strong> 已發佈</span>
        <span><strong>{stats.argmaps}</strong> 有論證地圖</span>
        <span><strong>{stats.total - stats.reports}</strong> 待補</span>
      </div>
    </header>

    {/* ── Meta tier: origin · capstones · deep-dive · bridge ───────── */}
    <section class="map-meta">
      <header class="map-meta__header">
        <p class="map-meta__label">M · 框架性文章</p>
        <h2 class="map-meta__title">起點、收束、橋接</h2>
        <p class="map-meta__intro">
          五篇位於 19 篇主體文章之外、用以框架整個系列的文章：
          四月的起點簡報、台灣深度案例、系列收束、0' 學術重述、Danielle Allen 橋接文。
        </p>
      </header>
      <ol class="map-meta__grid">
        {enrichedMeta.map((m) => (
          <li class="map-card" data-status={m.hasReport ? (m.hasArgmap ? "argmap" : "report") : "scheduled"}>
            <header class="map-card__top">
              <span class="map-card__no">#{m.no}</span>
              <span class="map-card__prompt">框架</span>
            </header>
            <h3 class="map-card__title">{m.title}</h3>
            <p class="map-meta__role">{m.role}</p>
            <footer class="map-card__links">
              {m.reportHref ? (
                <a class="map-card__link map-card__link--report" href={m.reportHref}>◈ 文章</a>
              ) : (
                <span class="map-card__link map-card__link--scheduled">◈ 待發佈</span>
              )}
              {m.argmapHref ? (
                <a class="map-card__link map-card__link--argmap" href={m.argmapHref}>◇ 論證地圖</a>
              ) : (
                <span class="map-card__link map-card__link--scheduled">◇ 待補</span>
              )}
            </footer>
          </li>
        ))}
      </ol>
    </section>

    {parts.map((part) => {
      const items = byPart(part.id);
      return (
        <section class="map-part" data-part={part.id} style={`--part-tint: ${partColors[part.id]};`}>
          <header class="map-part__header">
            <p class="map-part__label">{part.label}</p>
            <h2 class="map-part__title">{part.title}</h2>
            <p class="map-part__thesis">{part.thesis}</p>
          </header>

          <ol class="map-part__grid">
            {items.map((a) => (
              <li class="map-card" data-status={a.hasReport ? (a.hasArgmap ? "argmap" : "report") : "scheduled"}>
                <header class="map-card__top">
                  <span class="map-card__no">#{a.no}</span>
                  <span class="map-card__prompt">{a.prompt}</span>
                  <span class="map-card__chapter">{a.chapter}</span>
                </header>
                <h3 class="map-card__title">{a.title}</h3>
                {a.formalExpression && (
                  <pre class="map-card__formal"><code>{a.formalExpression}</code></pre>
                )}
                <footer class="map-card__links">
                  {a.reportHref ? (
                    <a class="map-card__link map-card__link--report" href={a.reportHref}>
                      ◈ 文章
                    </a>
                  ) : (
                    <span class="map-card__link map-card__link--scheduled">◈ 待發佈</span>
                  )}
                  {a.argmapHref ? (
                    <a class="map-card__link map-card__link--argmap" href={a.argmapHref}>
                      ◇ 論證地圖
                    </a>
                  ) : (
                    <span class="map-card__link map-card__link--scheduled">◇ 待補</span>
                  )}
                </footer>
              </li>
            ))}
          </ol>
        </section>
      );
    })}

    {/* ── 跨文章概念連結 ─────────────────────────── */}
    <section class="map-cross">
      <header class="map-cross__header">
        <p class="map-cross__label">概念連結</p>
        <h2 class="map-cross__title">跨文章概念連結</h2>
        <p class="map-cross__intro">
          公民證明可被理解為 ⟨𝒩, ℱ, ℬ⟩ 在不同子問題上的展開；23 篇文章共享同一形式骨幹。下表以形式邏輯標出文章之間的同構、遞迴、對偶、組合關係。
        </p>
      </header>

      <ul class="map-cross__list">
        {crossLinks.map((link) => {
          const fromArticle = enriched.find((a) => a.no === link.from);
          const toArticles = link.to
            .map((n) => enriched.find((a) => a.no === n))
            .filter((a): a is EnrichedArticle => !!a);
          return (
            <li class="map-cross__item">
              <div class="map-cross__row">
                <span class="map-cross__from">
                  {fromArticle?.argmapHref ? (
                    <a href={fromArticle.argmapHref}>#{link.from} {fromArticle?.title}</a>
                  ) : (
                    <span>#{link.from} {fromArticle?.title}</span>
                  )}
                </span>
                <span class="map-cross__arrow">⇒</span>
                <span class="map-cross__to">
                  {toArticles.map((t, i) => (
                    <>
                      {i > 0 && ", "}
                      {t.argmapHref ? (
                        <a href={t.argmapHref}>#{t.no}</a>
                      ) : t.reportHref ? (
                        <a href={t.reportHref}>#{t.no}</a>
                      ) : (
                        <span class="map-cross__pending">#{t.no}</span>
                      )}
                    </>
                  ))}
