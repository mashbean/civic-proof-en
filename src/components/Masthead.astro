---
import { SITE_TITLE, MAIN_SITE_URL } from "../site.config";

export interface Props {
  /** Override the brand line; defaults to SITE_TITLE. */
  brand?: string;
  /** Provide navigation links. */
  nav?: { href: string; label: string }[];
  /** Current locale for the page rendering this masthead. */
  locale?: "en" | "zh";
}

const { brand = SITE_TITLE, nav, locale = "en" } = Astro.props as Props;

const defaultNav =
  locale === "en"
    ? [
        { href: "/", label: "Series" },
        { href: "/civic-proof-map/", label: "Map" },
        { href: "/about/", label: "About" },
      ]
    : [
        { href: "/zh/", label: "系列" },
        { href: "/zh/civic-proof-map/", label: "論證地圖" },
        { href: "/zh/about/", label: "關於" },
      ];
const navItems = nav ?? defaultNav;

const homeHref = locale === "en" ? "/" : "/zh/";
const langSwitchHref = locale === "en" ? "/zh/" : "/";
const langSwitchLabel = locale === "en" ? "中文" : "English";
const langSwitchHrefLang = locale === "en" ? "zh-Hant" : "en";
const langSwitchTitle =
  locale === "en" ? "Switch to Chinese" : "Switch to English";
---

<header class="masthead">
  <a href={homeHref} class="masthead__brand">{brand}<span>.</span></a>
  <div class="masthead__right">
    <nav class="masthead__nav">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a
      class="masthead__lang"
      href={langSwitchHref}
      hreflang={langSwitchHrefLang}
      rel="alternate"
      title={langSwitchTitle}
    >
      {langSwitchLabel}
    </a>
    <a
      class="masthead__cta"
      href={MAIN_SITE_URL}
      target="_blank"
      rel="noopener"
    >
      ← mashbean.net
    </a>
  </div>
</header>
<div class="masthead__rule"></div>

<style>
  .masthead__right {
    display: flex;
    align-items: baseline;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .masthead__cta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink);
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-pill);
    transition: all var(--dur-fast) var(--ease-standard);
    white-space: nowrap;
  }
  .masthead__cta:hover {
    background: var(--color-ink);
    color: var(--color-canvas);
  }
  .masthead__lang {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    text-decoration: none;
    padding: 4px 10px;
    border: 1px solid transparent;
    border-radius: var(--radius-pill);
    transition: all var(--dur-fast) var(--ease-standard);
    white-space: nowrap;
  }
  .masthead__lang:hover {
    color: var(--color-ink);
    border-color: var(--color-ink-muted);
  }
  @media (max-width: 768px) {
    .masthead__right { gap: var(--space-3); }
    .masthead__cta { padding: 4px 10px; }
  }
</style>
