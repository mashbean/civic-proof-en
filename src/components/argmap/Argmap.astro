---
// 整張論證地圖（v2 — 加入 formal 公式 + transitions 接連描述 + role/pivot 為什麼）
import type { CollectionEntry } from "astro:content";

interface Props {
  argmap: CollectionEntry<"argmaps">;
  reportHref?: string;
  argdown?: {
    source?: string;
    htmlHref?: string;
    svgHref?: string;
    sourceHref?: string;
  };
}

const { argmap, reportHref, argdown } = Astro.props;
const data = argmap.data;
const transitions = data.transitions ?? {};
const hasArgdownRender = Boolean(argdown?.source || argdown?.htmlHref || argdown?.svgHref);
---

<section class="argmap">
  <header class="argmap__header">
    {reportHref && (
      <a href={reportHref} class="argmap__back">← Back to essay</a>
    )}
    <p class="argmap__kicker">Argument Map</p>
    <h1 class="argmap__title">{data.title}</h1>
    {data.subtitle && <p class="argmap__subtitle">{data.subtitle}</p>}
  </header>

  {/* ─ Core Thesis + Formal block ─────────────────────── */}
  <div class="argmap__thesis">
    <p class="argmap__thesis-text">{data.coreThesis.text}</p>
    {data.coreThesis.summary && (
      <p class="argmap__thesis-summary">{data.coreThesis.summary}</p>
    )}

    {data.coreThesis.formal && (
      <div class="argmap__formal">
        <div class="argmap__formal-label">Formal Notation</div>
        <pre class="argmap__formal-expr"><code>{data.coreThesis.formal.expression}</code></pre>
        {data.coreThesis.formal.caption && (
          <p class="argmap__formal-caption">{data.coreThesis.formal.caption}</p>
        )}
        {data.coreThesis.formal.legend.length > 0 && (
          <dl class="argmap__formal-legend">
            {data.coreThesis.formal.legend.map((l) => (
              <div class="argmap__formal-legend-item">
                <dt><code>{l.symbol}</code></dt>
                <dd>{l.meaning}</dd>
              </div>
            ))}
          </dl>
        )}
      </div>
    )}
  </div>

  {/* ─ Distinction ─────────────────────────────────────── */}
  {data.distinction && (
    <>
      {transitions.beforeDistinction && (
        <p class="argmap__transition">{transitions.beforeDistinction}</p>
      )}
      <div class="argmap__label">foundational distinction</div>
      <div class="argmap__distinction">
        <div class="argmap__dist-box argmap__dist-box--rejected">
          <div class="argmap__dist-label">{data.distinction.rejected.label}</div>
          <h3 class="argmap__dist-title">{data.distinction.rejected.title}</h3>
          <p class="argmap__dist-body">{data.distinction.rejected.body}</p>
          {data.distinction.rejected.formal && (
            <code class="argmap__dist-formal">{data.distinction.rejected.formal}</code>
          )}
        </div>
        <div class="argmap__dist-arrow" aria-hidden="true">→</div>
        <div class="argmap__dist-box argmap__dist-box--accepted">
          <div class="argmap__dist-label">{data.distinction.accepted.label}</div>
          <h3 class="argmap__dist-title">{data.distinction.accepted.title}</h3>
          <p class="argmap__dist-body">{data.distinction.accepted.body}</p>
          {data.distinction.accepted.formal && (
            <code class="argmap__dist-formal">{data.distinction.accepted.formal}</code>
          )}
        </div>
      </div>
    </>
  )}

  {/* ─ Pillars ─────────────────────────────────────────── */}
  {data.pillars.length > 0 && (
    <>
      {transitions.beforePillars && (
        <p class="argmap__transition">{transitions.beforePillars}</p>
      )}
      <div class="argmap__label">supporting arguments</div>
      <div class="argmap__pillars">
        {data.pillars.map((p) => (
          <div class="argmap__pillar">
            <p class="argmap__pillar-section">{p.section}</p>
            <h3 class="argmap__pillar-title">{p.title}</h3>
            {p.role && (
              <p class="argmap__pillar-role">
                <span class="argmap__pillar-role-tag">why</span>{p.role}
              </p>
            )}
            <p class="argmap__pillar-body">{p.body}</p>
            {p.finding && <div class="argmap__pillar-finding">{p.finding}</div>}
            {p.formal && (
              <code class="argmap__pillar-formal">{p.formal}</code>
            )}
          </div>
        ))}
      </div>
    </>
  )}

  {/* ─ Causal Chain ────────────────────────────────────── */}
  {data.chain && (
    <>
      {transitions.beforeChain && (
        <p class="argmap__transition">{transitions.beforeChain}</p>
      )}
      <div class="argmap__label">causal chain</div>
      <div class="argmap__chain">
        <p class="argmap__chain-title">{data.chain.title}</p>
        <div class="argmap__chain-list">
          {data.chain.steps.map((step, idx) => (
            <>
              <div class="argmap__chain-step">
                <div class={`argmap__chain-tag argmap__chain-tag--${step.kind}`}>
                  <span class="argmap__chain-tag-id">{step.tag}</span>
                  <span class="argmap__chain-tag-op">
                    {step.kind === "deterministic" ? "⇒" : "◊⇒"}
                  </span>
                </div>
                <div class={`argmap__chain-content argmap__chain-content--${step.kind}`}>
                  {step.text}
                </div>
              </div>
              {idx < data.chain!.steps.length - 1 && (
                <div class="argmap__chain-connector">
                  <div class="argmap__chain-connector-line"></div>
                  <div></div>
                </div>
              )}
            </>
          ))}
        </div>
        {data.chain.legend.length > 0 && (
          <div class="argmap__chain-legend">
            {data.chain.legend.map((l) => (
              <div class="argmap__legend-item">
                <span class={`argmap__legend-dot argmap__legend-dot--${l.kind}`}></span>
                <code class="argmap__legend-op">{l.kind === "deterministic" ? "⇒" : "◊⇒"}</code>
                {l.label}
              </div>
            ))}
          </div>
        )}
      </div>
    </>
  )}

  {/* ─ Border Cases ────────────────────────────────────── */}
  {data.borders.length > 0 && (
    <>
      {transitions.beforeBorders && (
        <p class="argmap__transition">{transitions.beforeBorders}</p>
      )}
      <div class="argmap__label">border cases — flip to support</div>
      <div class="argmap__borders">
        {data.borders.map((b) => (
          <div class="argmap__border">
            <p class="argmap__border-label">{b.label}</p>
            <h4 class="argmap__border-title">{b.title}</h4>
            {b.pivot && (
              <p class="argmap__border-pivot">
                <span class="argmap__border-pivot-tag">pivot</span>{b.pivot}
              </p>
            )}
            <p class="argmap__border-flip">{b.flip}</p>
          </div>
        ))}
      </div>
    </>
  )}

  {/* ─ Conditions ──────────────────────────────────────── */}
  {data.conditions && (
    <>
      {transitions.beforeConditions && (
        <p class="argmap__transition">{transitions.beforeConditions}</p>
      )}
      <div class="argmap__label">procedural conditions</div>
      <div class="argmap__conditions">
        {data.conditions.title && (
          <p class="argmap__conditions-title">{data.conditions.title}</p>
        )}
        {data.conditions.formalPrelude && (
          <pre class="argmap__conditions-formal"><code>{data.conditions.formalPrelude}</code></pre>
        )}
        <div class="argmap__conditions-grid">
          {data.conditions.items.map((c, idx) => (
            <div class="argmap__condition">
              <div class="argmap__condition-num">{idx + 1}</div>
              <div class="argmap__condition-text">
                <strong>{c.title}</strong>
                <p>{c.body}</p>
                {c.formal && (
                  <code class="argmap__condition-formal">{c.formal}</code>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </>
  )}

  {/* ─ Conclusion ──────────────────────────────────────── */}
  {data.conclusion && (
    <>
      {transitions.beforeConclusion && (
        <p class="argmap__transition">{transitions.beforeConclusion}</p>
      )}
      <div class="argmap__conclusion">
        {data.conclusion.paragraphs.map((p) => (
          <p set:html={p}></p>
        ))}
        {data.conclusion.formalCoda && (
          <pre class="argmap__conclusion-formal"><code>{data.conclusion.formalCoda}</code></pre>
        )}
      </div>
    </>
  )}

  {hasArgdownRender && (
    <section class="argmap__argdown" aria-labelledby="argdown-render-title">
      <div class="argmap__argdown-head">
        <div>
          <p class="argmap__argdown-kicker">Argdown</p>
          <h2 id="argdown-render-title" class="argmap__argdown-title">Formal Render</h2>
        </div>
        <div class="argmap__argdown-actions">
          {argdown?.htmlHref && <a href={argdown.htmlHref}>HTML</a>}
          {argdown?.sourceHref && <a href={argdown.sourceHref}>Source</a>}
        </div>
      </div>

      {argdown?.svgHref && (
        <a class="argmap__argdown-chart-link" href={argdown.svgHref}>
          <img
            class="argmap__argdown-chart"
            src={argdown.svgHref}
            alt={`${data.title} Argdown graph`}
            loading="lazy"
          />
        </a>
      )}

      {argdown?.source && (
        <details class="argmap__argdown-details">
          <summary>Source</summary>
          <pre class="argmap__argdown-source"><code>{argdown.source}</code></pre>
        </details>
      )}
    </section>
  )}
</section>

<style>
  @import "../../styles/argmap.css";
</style>
